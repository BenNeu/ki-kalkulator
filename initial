<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>24/7 Digitale Rezeption – ROI Kalkulator</title>
  <style>
    :root {
      --bg: #0d0f1a;
      --card: #161928;
      --card2: #1e2235;
      --accent: #4f8ef7;
      --accent2: #7c5cfc;
      --green: #22c55e;
      --red: #ef4444;
      --text: #f1f5f9;
      --muted: #94a3b8;
      --border: #2a3050;
      --radius: 16px;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Segoe UI', system-ui, sans-serif;
      min-height: 100vh;
      padding: 24px 16px 48px;
    }

    .wrapper {
      max-width: 960px;
      margin: 0 auto;
    }

    /* Header */
    .header {
      text-align: center;
      margin-bottom: 40px;
    }
    .header .badge {
      display: inline-block;
      background: linear-gradient(135deg, var(--accent), var(--accent2));
      color: #fff;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      padding: 4px 14px;
      border-radius: 100px;
      margin-bottom: 14px;
    }
    .header h1 {
      font-size: clamp(26px, 4vw, 42px);
      font-weight: 800;
      line-height: 1.15;
      background: linear-gradient(135deg, #fff 30%, var(--accent));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .header p {
      margin-top: 10px;
      color: var(--muted);
      font-size: 16px;
    }

    /* Grid layout */
    .grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }
    @media (max-width: 640px) {
      .grid { grid-template-columns: 1fr; }
    }

    /* Cards */
    .card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 28px;
    }
    .card.full { grid-column: 1 / -1; }

    .card-title {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 20px;
    }

    /* Inputs */
    .field { margin-bottom: 18px; }
    .field:last-child { margin-bottom: 0; }

    label {
      display: block;
      font-size: 13px;
      font-weight: 600;
      color: var(--muted);
      margin-bottom: 6px;
    }

    .input-wrap {
      position: relative;
    }
    .input-wrap .unit {
      position: absolute;
      right: 14px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--muted);
      font-size: 14px;
      pointer-events: none;
    }

    input[type="text"],
    input[type="number"] {
      width: 100%;
      background: var(--card2);
      border: 1.5px solid var(--border);
      border-radius: 10px;
      color: var(--text);
      font-size: 16px;
      font-weight: 600;
      padding: 12px 16px;
      outline: none;
      transition: border-color 0.2s;
    }
    input[type="number"] { padding-right: 44px; }
    input:focus {
      border-color: var(--accent);
    }
    input::placeholder { color: #3a4260; font-weight: 400; }

    /* Slider */
    .slider-row {
      display: flex;
      align-items: center;
      gap: 12px;
    }
    input[type="range"] {
      flex: 1;
      -webkit-appearance: none;
      height: 4px;
      border-radius: 4px;
      background: var(--border);
      outline: none;
      cursor: pointer;
    }
    input[type="range"]::-webkit-slider-thumb {
      -webkit-appearance: none;
      width: 20px;
      height: 20px;
      border-radius: 50%;
      background: var(--accent);
      cursor: pointer;
      box-shadow: 0 0 0 4px rgba(79,142,247,0.2);
    }
    .slider-val {
      min-width: 52px;
      text-align: right;
      font-weight: 700;
      font-size: 15px;
      color: var(--accent);
    }

    /* Results */
    .results-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
      margin-bottom: 20px;
    }
    @media (max-width: 600px) {
      .results-grid { grid-template-columns: 1fr 1fr; }
    }

    .metric {
      background: var(--card2);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 18px 16px;
      text-align: center;
    }
    .metric .m-label {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 1px;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 8px;
    }
    .metric .m-value {
      font-size: clamp(20px, 3vw, 28px);
      font-weight: 800;
      line-height: 1;
    }
    .metric .m-sub {
      font-size: 11px;
      color: var(--muted);
      margin-top: 4px;
    }
    .green { color: var(--green); }
    .blue  { color: var(--accent); }
    .purple{ color: #a78bfa; }

    /* ROI Banner */
    .roi-banner {
      background: linear-gradient(135deg, #0f2518, #0a1f3d);
      border: 1.5px solid var(--green);
      border-radius: 14px;
      padding: 24px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 16px;
      margin-bottom: 20px;
    }
    .roi-banner .roi-left h2 {
      font-size: clamp(14px, 2vw, 17px);
      font-weight: 700;
      color: var(--green);
      margin-bottom: 4px;
    }
    .roi-banner .roi-left p {
      font-size: 13px;
      color: #86efac;
    }
    .roi-banner .roi-right {
      text-align: right;
    }
    .roi-banner .roi-right .roi-number {
      font-size: clamp(28px, 5vw, 48px);
      font-weight: 900;
      color: var(--green);
      line-height: 1;
    }
    .roi-banner .roi-right .roi-label {
      font-size: 12px;
      color: #86efac;
      margin-top: 4px;
    }

    /* Closing Lines */
    .closing {
      background: var(--card2);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 22px 24px;
    }
    .closing .closing-title {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 14px;
    }
    .closing-lines {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .closing-line {
      background: var(--card);
      border-left: 3px solid var(--accent);
      border-radius: 0 8px 8px 0;
      padding: 12px 16px;
      font-size: 14px;
      font-style: italic;
      color: #cbd5e1;
      line-height: 1.5;
      transition: border-color 0.2s;
    }
    .closing-line:hover {
      border-color: var(--green);
      color: var(--text);
    }

    /* Comparison Bar */
    .comparison {
      margin-top: 20px;
    }
    .comp-row {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 12px;
    }
    .comp-label {
      width: 140px;
      font-size: 12px;
      font-weight: 600;
      color: var(--muted);
      flex-shrink: 0;
    }
    .comp-bar-wrap {
      flex: 1;
      background: var(--border);
      border-radius: 100px;
      height: 10px;
      overflow: hidden;
    }
    .comp-bar {
      height: 100%;
      border-radius: 100px;
      transition: width 0.6s cubic-bezier(.4,0,.2,1);
    }
    .comp-bar.ai   { background: linear-gradient(90deg, var(--accent), var(--accent2)); }
    .comp-bar.human { background: var(--red); }
    .comp-val {
      width: 90px;
      text-align: right;
      font-size: 13px;
      font-weight: 700;
    }

    /* Payback */
    .payback-box {
      margin-top: 16px;
      background: linear-gradient(135deg, #1a1040, #0f2030);
      border: 1.5px solid var(--accent2);
      border-radius: 12px;
      padding: 16px 20px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 8px;
    }
    .payback-box p {
      font-size: 13px;
      color: #c4b5fd;
    }
    .payback-box .payback-val {
      font-size: 22px;
      font-weight: 800;
      color: #a78bfa;
    }

    /* Footer */
    .footer {
      text-align: center;
      margin-top: 40px;
      color: var(--muted);
      font-size: 12px;
    }
    .footer strong { color: var(--accent); }

    /* Pulse animation for big numbers */
    @keyframes pop {
      0% { transform: scale(1); }
      50% { transform: scale(1.06); }
      100% { transform: scale(1); }
    }
    .pop { animation: pop 0.3s ease; }
  </style>
</head>
<body>
<div class="wrapper">

  <!-- Header -->
  <div class="header">
    <div class="badge">Digitale Rezeption · ROI Kalkulator</div>
    <h1>Was kostet dich jeder verpasste Anruf?</h1>
    <p>Fülle die Zahlen deines Betriebs aus — sieh in Echtzeit, was du gewinnst.</p>
  </div>

  <!-- Input + Results Grid -->
  <div class="grid">

    <!-- Inputs -->
    <div class="card">
      <div class="card-title">📋 Dein Betrieb</div>

      <div class="field">
        <label>Branche / Betrieb</label>
        <input type="text" id="branche" placeholder="z.B. Zahnarztpraxis Müller" oninput="calc()" />
      </div>

      <div class="field">
        <label>Verpasste Anrufe pro Tag</label>
        <div class="slider-row">
          <input type="range" id="anrufe_slider" min="1" max="80" value="15"
            oninput="syncSlider('anrufe','anrufe_slider');calc()">
          <span class="slider-val" id="anrufe_val">15</span>
        </div>
        <div class="input-wrap" style="margin-top:10px">
          <input type="number" id="anrufe" value="15" min="1" oninput="syncInput('anrufe','anrufe_slider');calc()" />
          <span class="unit">/ Tag</span>
        </div>
      </div>

      <div class="field">
        <label>Conversion Rate (% die buchen)</label>
        <div class="slider-row">
          <input type="range" id="conv_slider" min="5" max="90" value="40"
            oninput="syncSlider('conv','conv_slider');calc()">
          <span class="slider-val" id="conv_val">40%</span>
        </div>
      </div>

      <div class="field">
        <label>Ø Auftragswert / Kunde</label>
        <div class="input-wrap">
          <input type="number" id="auftrag" value="100" min="1" oninput="calc()" />
          <span class="unit">€</span>
        </div>
      </div>

      <div class="field">
        <label>Personalkosten Rezeption (aktuell)</label>
        <div class="input-wrap">
          <input type="number" id="personal" value="3000" min="0" oninput="calc()" />
          <span class="unit">€/Mo</span>
        </div>
      </div>

      <div class="field">
        <label>Dein Preis Digitale Rezeption</label>
        <div class="input-wrap">
          <input type="number" id="preis" value="399" min="1" oninput="calc()" />
          <span class="unit">€/Mo</span>
        </div>
      </div>
    </div>

    <!-- Metrics -->
    <div class="card">
      <div class="card-title">📈 Dein Ergebnis pro Monat</div>

      <div class="results-grid">
        <div class="metric">
          <div class="m-label">Verpasste Anrufe</div>
          <div class="m-value blue" id="r_anrufe_mo">450</div>
          <div class="m-sub">pro Monat</div>
        </div>
        <div class="metric">
          <div class="m-label">Neue Kunden</div>
          <div class="m-value green" id="r_kunden">180</div>
          <div class="m-sub">pro Monat</div>
        </div>
        <div class="metric">
          <div class="m-label">Mehrumsatz</div>
          <div class="m-value green" id="r_umsatz">18.000 €</div>
          <div class="m-sub">pro Monat</div>
        </div>
        <div class="metric">
          <div class="m-label">Kostenersparnis</div>
          <div class="m-value purple" id="r_ersparnis">2.601 €</div>
          <div class="m-sub">Personal vs. KI</div>
        </div>
        <div class="metric">
          <div class="m-label">Gesamtgewinn</div>
          <div class="m-value green" id="r_gesamt">20.601 €</div>
          <div class="m-sub">Umsatz + Ersparnis</div>
        </div>
        <div class="metric">
          <div class="m-label">ROI</div>
          <div class="m-value purple" id="r_roi">5169%</div>
          <div class="m-sub">Rendite auf 399€</div>
        </div>
      </div>

      <!-- ROI Banner -->
      <div class="roi-banner">
        <div class="roi-left">
          <h2 id="roi_headline">✅ System zahlt sich aus nach 1 Tag</h2>
          <p id="roi_sub">Jeder weitere Tag ist reiner Gewinn für dich.</p>
        </div>
        <div class="roi-right">
          <div class="roi-number" id="r_roi_x">52x</div>
          <div class="roi-label">Return on Investment</div>
        </div>
      </div>

      <!-- Payback -->
      <div class="payback-box">
        <p>💡 Investition amortisiert sich in:</p>
        <div class="payback-val" id="r_payback">unter 1 Tag</div>
      </div>
    </div>

    <!-- Cost Comparison - full width -->
    <div class="card full">
      <div class="card-title">⚖️ Kostenvergleich</div>
      <div class="comparison">
        <div class="comp-row">
          <div class="comp-label">Digitale Rezeption</div>
          <div class="comp-bar-wrap">
            <div class="comp-bar ai" id="bar_ai" style="width:8%"></div>
          </div>
          <div class="comp-val blue" id="bar_ai_val">399 €</div>
        </div>
        <div class="comp-row">
          <div class="comp-label">Menschliche Rezeption</div>
          <div class="comp-bar-wrap">
            <div class="comp-bar human" id="bar_human" style="width:100%"></div>
          </div>
          <div class="comp-val" style="color:var(--red)" id="bar_human_val">3.000 €</div>
        </div>
      </div>
    </div>

    <!-- Closing Lines - full width -->
    <div class="card full">
      <div class="closing">
        <div class="closing-title">🎯 Closing Lines für diesen Kunden</div>
        <div class="closing-lines" id="closing_lines">
          <!-- dynamisch befüllt -->
        </div>
      </div>
    </div>

  </div><!-- /grid -->

  <div class="footer">
    Powered by <strong>steuerwerk-KI</strong> · Digitale Rezeption für deinen Betrieb
  </div>

</div>

<script>
  // Slider <-> Input Sync
  function syncSlider(inputId, sliderId) {
    const slider = document.getElementById(sliderId);
    const val = slider.value;
    if (inputId === 'anrufe') {
      document.getElementById('anrufe').value = val;
      document.getElementById('anrufe_val').textContent = val;
    }
    if (inputId === 'conv') {
      document.getElementById('conv_val').textContent = val + '%';
    }
  }
  function syncInput(inputId, sliderId) {
    const input = document.getElementById(inputId);
    document.getElementById(sliderId).value = input.value;
    document.getElementById('anrufe_val').textContent = input.value;
  }

  function fmt(n) {
    return new Intl.NumberFormat('de-DE').format(Math.round(n));
  }

  function popEl(id) {
    const el = document.getElementById(id);
    el.classList.remove('pop');
    void el.offsetWidth;
    el.classList.add('pop');
  }

  function calc() {
    const anrufe  = parseFloat(document.getElementById('anrufe').value)  || 0;
    const conv    = parseFloat(document.getElementById('conv_slider').value) / 100 || 0;
    const auftrag = parseFloat(document.getElementById('auftrag').value)  || 0;
    const personal= parseFloat(document.getElementById('personal').value) || 0;
    const preis   = parseFloat(document.getElementById('preis').value)    || 399;
    const branche = document.getElementById('branche').value.trim() || 'deinen Betrieb';

    // Core math
    const anrufe_mo   = anrufe * 30;
    const neue_kunden = anrufe_mo * conv;
    const umsatz      = neue_kunden * auftrag;
    const ersparnis   = Math.max(0, personal - preis);
    const gesamt      = umsatz + ersparnis;
    const roi_pct     = preis > 0 ? ((gesamt - preis) / preis * 100) : 0;
    const roi_x       = preis > 0 ? (gesamt / preis) : 0;
    const payback_tage= gesamt > 0 ? (preis / (gesamt / 30)) : 999;

    // Update metrics
    document.getElementById('r_anrufe_mo').textContent = fmt(anrufe_mo);
    document.getElementById('r_kunden').textContent    = fmt(neue_kunden);
    document.getElementById('r_umsatz').textContent    = fmt(umsatz) + ' €';
    document.getElementById('r_ersparnis').textContent = fmt(ersparnis) + ' €';
    document.getElementById('r_gesamt').textContent    = fmt(gesamt) + ' €';
    document.getElementById('r_roi').textContent       = fmt(roi_pct) + '%';
    document.getElementById('r_roi_x').textContent     = roi_x.toFixed(1) + 'x';

    ['r_gesamt','r_umsatz','r_roi_x'].forEach(popEl);

    // Payback
    let paybackStr;
    if (payback_tage < 1)       paybackStr = 'unter 1 Tag';
    else if (payback_tage < 7)  paybackStr = Math.ceil(payback_tage) + ' Tage';
    else if (payback_tage < 30) paybackStr = Math.ceil(payback_tage / 7) + ' Wochen';
    else                        paybackStr = Math.ceil(payback_tage / 30) + ' Monate';
    document.getElementById('r_payback').textContent = paybackStr;

    // ROI Headline
    document.getElementById('roi_headline').textContent =
      payback_tage < 1
        ? '✅ System zahlt sich aus nach unter 1 Tag'
        : `✅ System zahlt sich aus nach ${paybackStr}`;
    document.getElementById('roi_sub').textContent =
      `Jeder weitere Tag ist reiner Gewinn für ${branche}.`;

    // Comparison bars
    const max = Math.max(personal, preis, 1);
    document.getElementById('bar_ai').style.width    = (preis   / max * 100).toFixed(1) + '%';
    document.getElementById('bar_human').style.width = (personal/ max * 100).toFixed(1) + '%';
    document.getElementById('bar_ai_val').textContent   = fmt(preis)    + ' €/Mo';
    document.getElementById('bar_human_val').textContent = fmt(personal) + ' €/Mo';

    // Closing Lines
    const lines = [
      `„Würdest du ${fmt(preis)} € zahlen, um ${fmt(gesamt)} € mehr pro Monat zu verdienen?"`,
      `„${branche} wäre die einzige Praxis in der Region, die 24/7 erreichbar ist."`,
      `„Dieses System zahlt sich in ${paybackStr} zurück — alles danach ist Gewinn."`,
      `„Du verlierst gerade ${fmt(umsatz)} € jeden Monat durch verpasste Anrufe."`,
    ];
    document.getElementById('closing_lines').innerHTML =
      lines.map(l => `<div class="closing-line">${l}</div>`).join('');
  }

  // Init
  calc();
</script>
</body>
</html>
